{
  "name": "@agentpack/registry",
  "version": "0.7.0-dev",
  "private": true,
  "description": "AgentPack Registry — the web UI for AgentPacks.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build:deps": "tsc -b ../../packages/core ../../packages/db",
    "predev": "pnpm build:deps",
    "dev": "next dev -p 3030",
    "prebuild": "pnpm build:deps",
    "build": "next build",
    "start": "next start -p 3030",
    "pretypecheck": "pnpm build:deps",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'lint: not configured'",
    "pretest": "pnpm build:deps",
    "test": "vitest run",
    "pretest:coverage": "pnpm build:deps",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "1.11.2",
    "@aws-sdk/client-s3": "3.1080.0",
    "@aws-sdk/s3-request-presigner": "3.1080.0",
    "@neondatabase/serverless": "1.1.0",
    "@agentpack/core": "workspace:*",
    "@agentpack/db": "workspace:*",
    "drizzle-orm": "0.45.2",
    "next": "15.5.18",
    "next-auth": "5.0.0-beta.31",
    "postgres": "3.4.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "yaml": "2.9.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.10",
    "autoprefixer": "10.5.2",
    "postcss": "8.5.16",
    "tailwindcss": "3.4.17",
    "typescript": "5.6.3",
    "vite": "6.4.3",
    "vitest": "4.1.10"
  }
}
