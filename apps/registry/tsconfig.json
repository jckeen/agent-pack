{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "allowJs": true,
    "incremental": true,
    "paths": {
      "@/*": ["./*"]
    },
    "types": ["node"],
    "noEmit": true
  },
  "references": [{ "path": "../../packages/core" }, { "path": "../../packages/db" }],
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", ".next"]
}
