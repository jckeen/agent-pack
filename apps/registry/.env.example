# =============================================================================
# AgentPack Registry — environment variables
# =============================================================================
#
# Local dev: copy to `.env.local`, fill in, run `pnpm dev`.
# Vercel:    use `vercel env add <NAME> production` (and `preview` / `development`).
# CI:        these go in repo Actions secrets, mirrored to Vercel preview env.
#
# Without any of these set, the registry boots in JSON-fallback mode for local
# browsing of the seed packs (the homepage, /packs, /docs, /validate all work).
# Anything that touches DB / R2 / Auth returns 503 with `{"error":"db_unconfigured"}`
# or equivalent.
#
# =============================================================================
# Required for production
# =============================================================================

# Postgres — Neon serverless connection string. Pooler URL (port 6543) preferred.
# Get from: https://console.neon.tech/<project>/branches → branch → "Connection string"
DATABASE_URL="postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/registry?sslmode=require"

# NextAuth v5 secret — `openssl rand -hex 32`
AUTH_SECRET=""

# Public URL of the deployed registry. Used by NextAuth callback resolution and
# by the CLI device-code flow's redirect target.
NEXT_PUBLIC_REGISTRY_URL="https://registry.agentpack.dev"

# GitHub OAuth App — for user sign-in (web) and CLI device-code authorization.
# Create at: https://github.com/settings/applications/new
# Authorization callback URL: <NEXT_PUBLIC_REGISTRY_URL>/api/auth/callback/github
GITHUB_ID=""
GITHUB_SECRET=""

# Cloudflare R2 — S3-compatible object storage for pack artifacts.
# Get from: Cloudflare Dashboard → R2 → Manage R2 API Tokens → "Create API token".
# Scope token to a single bucket; permissions: "Object Read & Write".
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="agentpack-artifacts"

# =============================================================================
# Optional
# =============================================================================

# Sigstore (Phase 4) — passing this lets `agentpack publish --sign` request an
# OIDC token from the user's environment. CI builds set this automatically via
# GitHub Actions OIDC. Local devs can use `gh auth token` and `export SIGSTORE_ID_TOKEN=...`.
# SIGSTORE_ID_TOKEN=""

# Postgres connection pool size for the registry's DB client. Read by
# @agentpack/db (packages/db/src/client.ts); parsed as an integer, defaults to 10.
# DATABASE_POOL_MAX="10"
