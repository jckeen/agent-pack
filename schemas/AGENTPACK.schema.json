{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentpack.dev/schemas/agentpack.schema.json",
  "title": "AgentPack Manifest",
  "type": "object",
  "required": [
    "agentpack",
    "metadata",
    "compatibility",
    "profiles",
    "atoms"
  ],
  "properties": {
    "agentpack": {
      "type": "string",
      "pattern": "^1\\.\\d+"
    },
    "metadata": {
      "type": "object",
      "required": [
        "id",
        "name",
        "slug",
        "description",
        "version",
        "publisher"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "slug": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "license": {
          "type": "string"
        },
        "publisher": {
          "type": "string"
        },
        "authors": {
          "type": "array"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "compatibility": {
      "type": "object"
    },
    "permissions": {
      "type": "object"
    },
    "security": {
      "type": "object"
    },
    "profiles": {
      "type": "object"
    },
    "dependencies": {
      "type": "object"
    },
    "atoms": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "name",
          "description",
          "risk_level"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "enum": [
              "instruction",
              "rule",
              "skill",
              "hook",
              "command",
              "subagent",
              "mcp_server",
              "plugin",
              "workflow",
              "context_pack",
              "template",
              "eval"
            ]
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "risk_level": {
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "body": {
            "type": "string",
            "minLength": 1,
            "description": "Inline default body — alternative to `path` (#133)."
          },
          "variants": {
            "type": "object",
            "description": "Per-target source/body overrides keyed by target platform; the atom keeps one id while each target compiles its own variant (#133).",
            "properties": {
              "claude-code": {
                "type": "object",
                "description": "Target-specific atom source (#133): exactly one of `path` (pack-relative file) or `body` (inline content).",
                "properties": {
                  "path": {
                    "type": "string"
                  },
                  "body": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "oneOf": [
                  {
                    "required": [
                      "path"
                    ]
                  },
                  {
                    "required": [
                      "body"
                    ]
                  }
                ],
                "additionalProperties": false
              },
              "codex": {
                "type": "object",
                "description": "Target-specific atom source (#133): exactly one of `path` (pack-relative file) or `body` (inline content).",
                "properties": {
                  "path": {
                    "type": "string"
                  },
                  "body": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "oneOf": [
                  {
                    "required": [
                      "path"
                    ]
                  },
                  {
                    "required": [
                      "body"
                    ]
                  }
                ],
                "additionalProperties": false
              },
              "cursor": {
                "type": "object",
                "description": "Target-specific atom source (#133): exactly one of `path` (pack-relative file) or `body` (inline content).",
                "properties": {
                  "path": {
                    "type": "string"
                  },
                  "body": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "oneOf": [
                  {
                    "required": [
                      "path"
                    ]
                  },
                  {
                    "required": [
                      "body"
                    ]
                  }
                ],
                "additionalProperties": false
              },
              "chatgpt": {
                "type": "object",
                "description": "Target-specific atom source (#133): exactly one of `path` (pack-relative file) or `body` (inline content).",
                "properties": {
                  "path": {
                    "type": "string"
                  },
                  "body": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "oneOf": [
                  {
                    "required": [
                      "path"
                    ]
                  },
                  {
                    "required": [
                      "body"
                    ]
                  }
                ],
                "additionalProperties": false
              },
              "generic": {
                "type": "object",
                "description": "Target-specific atom source (#133): exactly one of `path` (pack-relative file) or `body` (inline content).",
                "properties": {
                  "path": {
                    "type": "string"
                  },
                  "body": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "oneOf": [
                  {
                    "required": [
                      "path"
                    ]
                  },
                  {
                    "required": [
                      "body"
                    ]
                  }
                ],
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        },
        "anyOf": [
          {
            "required": [
              "path"
            ]
          },
          {
            "required": [
              "body"
            ]
          },
          {
            "required": [
              "variants"
            ]
          }
        ]
      }
    },
    "exports": {
      "type": "object"
    },
    "adapters": {
      "type": "object"
    }
  }
}
