{
  "name": "@agentpack/cli",
  "version": "0.7.0-dev",
  "description": "agentpack CLI — validate, inspect, plan, export, install, uninstall, verify, and rollback AgentPacks.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jckeen/agent-pack.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/jckeen/agent-pack#readme",
  "bugs": {
    "url": "https://github.com/jckeen/agent-pack/issues"
  },
  "keywords": [
    "agentpack",
    "agents",
    "ai-agents",
    "agent-configuration",
    "claude-code",
    "codex",
    "cursor",
    "cli",
    "skills",
    "mcp"
  ],
  "type": "module",
  "bin": {
    "agentpack": "./dist/index.js"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "typecheck": "tsc -b tsconfig.json",
    "dev": "tsx src/index.ts",
    "prebuild:check": "tsc -b tsconfig.json",
    "pretest": "tsc -b tsconfig.json",
    "pretest:coverage": "tsc -b tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@agentpack/core": "workspace:*",
    "commander": "15.0.0",
    "diff": "9.0.0",
    "ora": "8.1.1",
    "picocolors": "1.1.1"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@vitest/coverage-v8": "4.1.10",
    "tsx": "4.23.1",
    "typescript": "5.6.3",
    "vite": "6.4.3",
    "vitest": "4.1.10"
  }
}
