{
  "name": "@workgraph/cli",
  "version": "0.1.1",
  "private": true,
  "description": "workgraph CLI — validate, inspect, plan, and export AgentPacks.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "workgraph": "./dist/index.js"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/index.ts",
    "prebuild:check": "tsc -p tsconfig.json --noEmit",
    "pretest": "pnpm --filter @workgraph/core build && tsc -p tsconfig.json",
    "pretest:coverage": "pnpm --filter @workgraph/core build && tsc -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@workgraph/core": "workspace:*",
    "commander": "12.1.0",
    "diff": "7.0.0",
    "ora": "8.1.1",
    "picocolors": "1.1.1"
  },
  "devDependencies": {
    "@types/diff": "6.0.0",
    "@types/node": "22.10.2",
    "@vitest/coverage-v8": "2.1.8",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "vitest": "2.1.8"
  }
}
