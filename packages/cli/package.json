{
  "name": "@agentpack/cli",
  "version": "0.7.0-dev",
  "private": true,
  "description": "agentpack CLI — validate, inspect, plan, export, install, uninstall, verify, and rollback AgentPacks.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "agentpack": "./dist/index.js"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "typecheck": "tsc -b tsconfig.json",
    "dev": "tsx src/index.ts",
    "prebuild:check": "tsc -b tsconfig.json",
    "pretest": "tsc -b tsconfig.json",
    "pretest:coverage": "tsc -b tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@agentpack/core": "workspace:*",
    "commander": "12.1.0",
    "diff": "9.0.0",
    "ora": "8.1.1",
    "picocolors": "1.1.1"
  },
  "devDependencies": {
    "@types/diff": "6.0.0",
    "@types/node": "22.10.2",
    "@vitest/coverage-v8": "2.1.9",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "vitest": "2.1.9"
  }
}
