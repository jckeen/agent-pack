{
  "name": "@agentpack/connector",
  "version": "0.1.0",
  "private": true,
  "description": "Prototype remote MCP connector that exposes an AgentPack's guidance (skills, commands, instructions, rules) as MCP prompts and resources — reaching every Claude surface, including claude.ai chat and mobile/Dispatch where plugins can't.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "agentpack-connector": "./dist/serve.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "dev": "tsx src/serve.ts",
    "start": "node dist/serve.js"
  },
  "dependencies": {
    "@agentpack/core": "workspace:*",
    "@hono/node-server": "2.0.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": "4.12.25",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@vitest/coverage-v8": "2.1.9",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "vitest": "2.1.9"
  }
}
