{
  "name": "@agentpack/core",
  "version": "0.7.0-dev",
  "private": true,
  "description": "AgentPack core: schema, parser, validator, permissions, risk, planner, adapters.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js"
    },
    "./seed": {
      "types": "./dist/seed/seedPacks.d.ts",
      "import": "./dist/seed/seedPacks.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@sigstore/bundle": "5.0.0",
    "@sigstore/sign": "5.0.0",
    "diff": "9.0.0",
    "fflate": "0.8.3",
    "sigstore": "5.0.0",
    "smol-toml": "1.7.0",
    "yaml": "2.9.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/diff": "6.0.0",
    "@types/node": "22.10.2",
    "@vitest/coverage-v8": "4.1.10",
    "typescript": "5.6.3",
    "vite": "6.4.3",
    "vitest": "4.1.10"
  }
}
