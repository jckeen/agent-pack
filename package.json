{
  "name": "agent-pack",
  "version": "0.1.0",
  "private": true,
  "description": "AgentPack standard + Workgraph Registry — write once, install anywhere agents work.",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build && pnpm --filter @workgraph/registry build",
    "dev": "pnpm --filter @workgraph/registry dev",
    "test": "pnpm -r --filter \"./packages/*\" test",
    "test:coverage": "pnpm -r --filter \"./packages/*\" test:coverage",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint \"packages/*/src/**/*.ts\" \"packages/*/tests/**/*.ts\" \"apps/*/{app,components,lib}/**/*.{ts,tsx}\"",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yaml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,yaml}\" --ignore-path .gitignore",
    "cli": "pnpm --filter @workgraph/cli exec workgraph",
    "verify": "pnpm typecheck && pnpm lint && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "8.18.1",
    "@typescript-eslint/parser": "8.18.1",
    "eslint": "9.17.0",
    "prettier": "3.4.2",
    "typescript": "5.6.3",
    "typescript-eslint": "8.18.1"
  }
}
