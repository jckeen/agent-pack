{
  "name": "agent-pack",
  "version": "0.1.0",
  "private": true,
  "description": "AgentPack standard + Workgraph Registry — write once, install anywhere agents work.",
  "license": "MIT",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build && pnpm --filter @workgraph/registry build",
    "dev": "pnpm --filter @workgraph/registry dev",
    "test": "pnpm -r --filter \"./packages/*\" test",
    "typecheck": "pnpm -r typecheck",
    "lint": "echo 'lint: not configured in MVP'",
    "cli": "pnpm --filter @workgraph/cli exec workgraph"
  },
  "devDependencies": {
    "typescript": "5.6.3"
  }
}
